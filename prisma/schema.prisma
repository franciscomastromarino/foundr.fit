generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ NextAuth tables ============
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  profile       Profile?

  connectionsFrom Connection[] @relation("ConnectionFrom")
  connectionsTo   Connection[] @relation("ConnectionTo")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ============ Founder Radar tables ============
model Profile {
  id                 String   @id
  fullName           String
  avatarUrl          String?
  whatsappE164       String
  role               String
  startup            String
  industries         String[]
  lookingFor         String[]
  offering           String[]
  bio                String?  @db.VarChar(280)
  city               String?
  linkedinUrl        String?
  community          String   @default("emprending")
  onboardingStep     Int      @default(1)
  onboardingComplete Boolean  @default(false)
  visible            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@index([community, visible, onboardingComplete])
  @@index([lookingFor], type: Gin)
  @@index([industries], type: Gin)
}

model Connection {
  id        String   @id @default(cuid())
  fromUser  String
  toUser    String
  createdAt DateTime @default(now())

  from User @relation("ConnectionFrom", fields: [fromUser], references: [id], onDelete: Cascade)
  to   User @relation("ConnectionTo", fields: [toUser], references: [id], onDelete: Cascade)

  @@unique([fromUser, toUser])
  @@index([fromUser])
  @@index([toUser])
}
